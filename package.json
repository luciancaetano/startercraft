{
  "name": "startercraft-template",
  "description": "An **opinionated boilerplate** designed to accelerate the development of modern, scalable React applications with TypeScript.",
  "version": "1.1.8",
  "private": true,
  "type": "module",
  "author": {
    "name": "Lucian Caetano"
  },
  "license": "CC0-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/luciancaetano/startercraft.git"
  },
  "scripts": {
    "start": "vite --host",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:staged": "cross-env CI=1 react-scripts test --findRelatedTests",
    "test": "vitest --coverage",
    "postinstall": "husky install",
    "lint": "eslint --fix .",
    "serve": "serve --no-clipboard --single --listen 3000 dist",
    "generate": "plop",
    "validate-types": "tsc --project tsconfig.json --pretty --noEmit",
    "validate": "yarn validate-types && yarn lint && yarn test"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "history": "^5.3.0",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "lodash": "^4.17.23",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-i18next": "^16.5.5",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "type-fest": "^5.4.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@mswjs/data": "^0.16.2",
    "@startercraft/cli": "^1.0.1",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/marked": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "@vitest/coverage-istanbul": "^4.0.18",
    "autoprefixer": "^10",
    "browserslist-to-esbuild": "^2.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-testing-library": "^7.16.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "is-ci": "^4.1.0",
    "is-ci-cli": "^2.2.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "msw": "^2.12.10",
    "npm-run-all": "^4.1.5",
    "plop": "^4.0.5",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.2.4",
    "sass": "^1.97.3",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "vite-plugin-string": "^1.2.3",
    "vite-vitals": "^1.0.2",
    "vitest": "^4.0.18"
  },
  "eslintConfig": {
    "overrides": [
      {
        "files": [
          "**/*.stories.*"
        ],
        "rules": {
          "import/no-anonymous-default-export": "off"
        }
      }
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.+(ts|tsx|js)": [
      "yarn lint",
      "npm run test:staged",
      "git add"
    ]
  },
  "resolutions": {
    "vitest": "^0.34.0"
  }
}

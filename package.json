{
  "name": "startercraft-template",
  "description": "An **opinionated boilerplate** designed to accelerate the development of modern, scalable React applications with TypeScript.",
  "version": "1.1.8",
  "private": true,
  "type": "module",
  "author": {
    "name": "Lucian Caetano"
  },
  "license": "CC0-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/luciancaetano/startercraft.git"
  },
  "scripts": {
    "start": "vite --host",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest --coverage",
    "test:coverage": "vitest --run --coverage",
    "postinstall": "husky install",
    "lint": "eslint --fix .",
    "generate": "plop",
    "validate-types": "tsc --project tsconfig.json --pretty --noEmit",
    "validate": "npm run validate-types && npm run lint && npm run test"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@startercraft/cli": "^1.0.1",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "@vitest/coverage-istanbul": "^4.0.18",
    "browserslist-to-esbuild": "^2.1.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-testing-library": "^7.16.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "msw": "^2.12.10",
    "npm-run-all": "^4.1.5",
    "plop": "^4.0.5",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vite-vitals": "^1.0.2",
    "vitest": "^4.0.18"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.+(ts|tsx|js)": [
      "eslint --fix",
      "git add"
    ]
  }
}

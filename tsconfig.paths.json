{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@features/*": [
        "./src/app/features/*"
      ],
      "@locales/*": [
        "./src/locales/*"
      ],
      "@components/*": [
        "./src/app/components/*"
      ],
      "@config/*": [
        "./src/app/config/*"
      ],
      "@hooks/*": [
        "./src/app/hooks/*"
      ],
      "@utils/*": [
        "./src/app/utils/*"
      ],
      "@assets/*": [
        "./src/assets/*"
      ],
      "@domain/*": [
        "./src/app/domain/*"
      ]
    }
  }
}
